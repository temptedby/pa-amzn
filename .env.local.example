# Copy to .env.local and fill in. .env.local is gitignored.

# --- Database ---
# Dev: leave blank, defaults to file:./data/pa-amzn.db
# Prod: Turso URL, e.g. libsql://pa-amzn-you.turso.io
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# --- Amazon SP-API ---
SP_API_REFRESH_TOKEN=
SP_API_SOLUTION_ID=amzn1.sp.solution.34045c22-27c6-44df-b25c-1c66493241aa
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=

# --- Amazon Ads API (separate OAuth — submit registration at advertising.amazon.com) ---
ADS_API_REFRESH_TOKEN=
ADS_API_CLIENT_ID=
ADS_API_CLIENT_SECRET=
ADS_API_PROFILE_ID=

# --- Auth ---
DASHBOARD_PASSWORD=
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
ALERT_EMAIL=hello@phoneassured.com
